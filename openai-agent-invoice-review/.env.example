# Relayna API connection
RELAYNA_BASE_URL=http://localhost:4000
RELAYNA_API_KEY=relayna:your_key_here

# OpenAI API key
OPENAI_API_KEY=sk-...

# Agent behaviour
MAX_REVISIONS=2               # max needs_changes loops before auto-rejecting
POLL_INTERVAL_SECONDS=15      # how often to poll for a human decision
CHECKPOINT_TTL_SECONDS=86400  # how long the review link stays valid (24h)
REVIEW_THRESHOLD=100          # invoices at or below this amount are auto-approved
