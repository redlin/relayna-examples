# ── Relayna ────────────────────────────────────────────────────────────────
# Base URL of your Relayna instance (no trailing slash)
RELAYNA_BASE_URL=https://relayna.app

# API key generated from the Relayna dashboard (/dashboard/api-keys)
RELAYNA_API_KEY=relayna:your_api_key_here

# ── OpenAI ──────────────────────────────────────────────────────────────────
# OpenAI API key — used to extract structured data from the PDF
OPENAI_API_KEY=sk-...

# ── Workflow settings ───────────────────────────────────────────────────────
# How often (seconds) to poll the checkpoint status endpoint
POLL_INTERVAL_SECONDS=15

# How many needs_changes revision loops to allow before giving up
MAX_REVISIONS=2

# Checkpoint time-to-live in seconds (default 24h)
CHECKPOINT_TTL_SECONDS=86400

# ── Webhook mode (optional) ─────────────────────────────────────────────────
# Port for the local FastAPI webhook receiver (used with --webhook flag)
WEBHOOK_PORT=8765

# Public URL Relayna will POST decisions to (must be reachable from Relayna)
# For local dev with Relayna on the same machine:
WEBHOOK_CALLBACK_URL=http://localhost:8765/webhook
